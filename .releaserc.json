{
  "branches": ["main"],
  "repositoryUrl": "https://github.com/GameFrameX/GameFrameX.Tools.git",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "dotnet publish ProtoExport/ProtoExport.csproj -c Release -r linux-x64 --self-contained true -p:PublishSingleFile=true -o ./release-assets && docker build -t alianhome/gameframex-tools:${nextRelease.version} -t alianhome/gameframex-tools:latest .",
        "publishCmd": "docker push alianhome/gameframex-tools:${nextRelease.version} && docker push alianhome/gameframex-tools:latest"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "release-assets/ProtoExport",
            "label": "ProtoExport-linux-x64"
          }
        ]
      }
    ]
  ]
}
